# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Gmail OAuth2
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=http://localhost:8080/oauth2callback
GMAIL_BATCH_SIZE=50
GMAIL_DRY_RUN=true
JARVIS_CONFIG_DIR=/config/personal
JARVIS_DATA_DIR=/data

# Google Calendar
GOOGLE_CALENDAR_IDS=primary,your-family-calendar-id@group.calendar.google.com,en.canadian#holiday@group.v.calendar.google.com
JARVIS_TIMEZONE=America/Toronto

# Morning briefing
JARVIS_CITY=Your City

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-access-token

# Spotify
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Database
JARVIS_DB_PATH=/data/jarvis.db

# Tailscale (VPS <-> Pi communication)
TAILSCALE_PI_IP=100.x.x.x
TAILSCALE_VPS_IP=100.x.x.x
